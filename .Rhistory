use_mit_license()
library(usethis)
use_mit_license()
devtools::document()
# Esto simula la instalación y carga de tu paquete directamente en la memoria
devtools::load_all()
# Esto llama a tu nuevo manual de ayuda oficial
?paper_engine
# Clear environment
rm(list = ls())
# CARGAR EL PAQUETE COMPLETO (Sustituye a source)
devtools::load_all()
# 1. Simulate experiment data (3 groups)
set.seed(456)
n_per_group <- 50
# Create a categorical variable (Factor)
group <- factor(rep(c("Control", "Treatment A", "Treatment B"), each = n_per_group))
# Simulate dependent variable with real differences between groups
y_control <- rnorm(n_per_group, mean = 50, sd = 10)
y_treat_A  <- rnorm(n_per_group, mean = 65, sd = 10) # Positive effect
y_treat_B  <- rnorm(n_per_group, mean = 52, sd = 10) # Minimal effect
y <- c(y_control, y_treat_A, y_treat_B)
experiment_data <- data.frame(y, group)
# 2. Test the Main Function (Routing to ANOVA)
cat("\n======================================================\n")
cat("--- PAPER READY OUTPUT (ANOVA) ---\n")
cat("======================================================\n")
anova_model <- paper_engine(y ~ group, data = experiment_data, model = "anova")
cat("\n>> TABLE 4: MAIN CONTRAST (F and Effect Size)\n")
print(anova_model$tables$Table4_ANOVA)
cat("\n>> DESCRIPTIVE MEANS TABLE\n")
print(anova_model$tables$Descriptive_Means)
cat("\n>> CUSTOMS MESSAGES (Levene's Test)\n")
print(anova_model$messages)
# 3. PROBAR EL NUEVO MOTOR VISUAL (Gráfico Paper-Ready)
cat("\n>> GENERANDO GRÁFICO APA EN EL PANEL DE PLOTS...\n")
plot_engine(anova_model, y_label = "Satisfacción del Cliente")
